{
  "name": "dnd-beginner-character-sheet-5e-2024",
  "description": "A simple, interactive D&D 5e character sheet built for new players and the 2024 rules",
  "type": "module",
  "version": "0.0.2",
  "private": false,
  "license": "MIT",
  "author": "Manu Artero <manutero.developer@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/manuartero/dnd-beginner-character-sheet-5e-2024.git"
  },
  "homepage": "https://github.com/manuartero/dnd-beginner-character-sheet-5e-2024#readme",
  "bugs": {
    "url": "https://github.com/manuartero/dnd-beginner-character-sheet-5e-2024/issues"
  },
  "keywords": [
    "dnd",
    "d&d",
    "dungeons-and-dragons",
    "character-sheet",
    "character-sheet-builder",
    "character-sheet-generator",
    "simple-character-sheet",
    "5e",
    "5th-edition",
    "2024",
    "beginner",
    "ttrpg",
    "tabletop",
    "rpg"
  ],
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "lint": "biome check .",
    "format": "biome format . --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "blue-ball": "pnpm lint && pnpm test && pnpm build",
    "blue-ball:release": "pnpm blue-ball && pnpm test:coverage && ./.hooks/update-coverage-badge.sh"
  },
  "dependencies": {
    "@astrojs/react": "4.4.2",
    "@types/react": "19.2.13",
    "@types/react-dom": "19.2.3",
    "astro": "5.17.1",
    "classnames": "2.5.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/jest": "30.0.0",
    "@vitest/coverage-v8": "4.0.18",
    "jsdom": "28.0.0",
    "vitest": "4.0.18"
  }
}
