{
  "permissions": {
    "allow": [
      "Bash(chmod:*)",
      "Bash(curl:*)",
      "Bash(find:*)",
      "Bash(git add:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(ls:*)",
      "Bash(npx skills find:*)",
      "Bash(pnpm:*)",
      "Bash(python3:*)",
      "Bash(xargs:*)",
      "WebFetch(domain:bg3.wiki)",
      "WebFetch(domain:fonts.googleapis.com)",
      "WebFetch(domain:www.dndbeyond.com)",
      "WebSearch",
      "Bash(sed -i '' 's|import { Inventory } from \"\"src/components/inventory/inventory\"\";|import { Inventory, ProficiencyGrid, ScreenFlash, Stepper } from \"\"elements\"\";|' src/components/character-sheet/character-sheet.tsx)",
      "Bash(sed -i '' '/import { ProficiencyGrid } from \"\"src\\\\/components\\\\/proficiency-grid\"\";/d' src/components/character-sheet/character-sheet.tsx)",
      "Bash(sed -i '' '/import { ScreenFlash } from \"\"src\\\\/components\\\\/screen-flash\\\\/screen-flash\"\";/d' src/components/character-sheet/character-sheet.tsx)",
      "Bash(sed -i '' '/import { Stepper } from \"\"src\\\\/components\\\\/stepper\\\\/stepper\"\";/d' src/components/character-sheet/character-sheet.tsx)",
      "Bash(sed -i '' 's|import { ActionButtonGrid } from \"\"src/components/action-button-grid/action-button-grid\"\";|import { ActionButtonGrid, CastSpellGrid, Section } from \"\"elements\"\";|' src/components/character-sheet/action-bar/action-bar.tsx)",
      "Bash(sed -i '' '/import { CastSpellGrid } from \"\"src\\\\/components\\\\/cast-spell-grid\\\\/cast-spell-grid\"\";/d' src/components/character-sheet/action-bar/action-bar.tsx)",
      "Bash(sed -i '' '/import { Section } from \"\"src\\\\/components\\\\/section\"\";/d' src/components/character-sheet/action-bar/action-bar.tsx)",
      "Bash(sed -i '' 's|import type { GridAction } from \"\"src/components/action-button-grid/action-button-grid\"\";|import type { GridAction } from \"\"elements\"\";|' src/components/character-sheet/action-bar/action-bar.tsx)",
      "Bash(sed -i '' 's|import { AbilityCard } from \"\"src/components/ability-card\"\";|import { AbilityCard, Section } from \"\"elements\"\";|' src/components/character-sheet/ability-scores/ability-scores.tsx)",
      "Bash(sed -i '' '/import { Section } from \"\"src\\\\/components\\\\/section\"\";/d' src/components/character-sheet/ability-scores/ability-scores.tsx)",
      "Bash(sed -i '' 's|import { Section } from \"\"src/components/section\"\";|import { Section } from \"\"elements\"\";|' src/components/character-sheet/spell-cards/spell-cards.tsx)",
      "Bash(sed -i '' 's|import { Section } from \"\"src/components/section\"\";|import { Section } from \"\"elements\"\";|' src/components/character-sheet/hp-tracker/hp-tracker.tsx)",
      "Bash(sed -i '' 's|import { ActionButtonGrid } from \"\"src/components/action-button-grid/action-button-grid\"\";|import { ActionButtonGrid, Section } from \"\"elements\"\";|' src/components/character-sheet/exploration-bar/exploration-bar.tsx)",
      "Bash(sed -i '' '/import { Section } from \"\"src\\\\/components\\\\/section\"\";/d' src/components/character-sheet/exploration-bar/exploration-bar.tsx)",
      "Bash(sed -i '' 's|import { Section } from \"\"src/components/section\"\";|import { Section } from \"\"elements\"\";|' src/components/character-sheet/character-header/character-header.tsx)",
      "Bash(sed -i '' 's|import { CombatChip } from \"\"src/components/combat-chip/combat-chip\"\";|import { CombatChip, Section } from \"\"elements\"\";|' src/components/character-sheet/combat-stats/combat-stats.tsx)",
      "Bash(sed -i '' '/import { Section } from \"\"src\\\\/components\\\\/section\"\";/d' src/components/character-sheet/combat-stats/combat-stats.tsx)",
      "Bash(sed -i '' 's|import { Section } from \"\"src/components/section\"\";|import { Section } from \"\"elements\"\";|' src/components/character-sheet/weapon-mastery/weapon-mastery.tsx)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.hooks/enforce-pnpm.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.hooks/enforce-kebab-case.sh"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.hooks/enforce-no-utils-dir.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.hooks/enforce-no-default-export.sh"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.hooks/enforce-exact-versions.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm blue-ball"
          }
        ]
      }
    ]
  }
}
